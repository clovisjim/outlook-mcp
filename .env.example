# ==========================================================================
# Outlook MCP Server — Environment Variables
# ==========================================================================
# Copy this file to .env and fill in the values.
# For Railway deployment, set these as Railway service variables instead.
# ==========================================================================

# ---------- Microsoft Azure App Registration ----------
# Get these from Azure Portal > App Registrations > Your App

# Application (client) ID from Azure Portal
MS_CLIENT_ID=your-client-id-here

# Client secret VALUE (not the secret ID)
# Azure Portal > App Registrations > Your App > Certificates & secrets
MS_CLIENT_SECRET=your-client-secret-here

# ---------- Cloud Deployment (Railway) ----------

# Public URL of this server (Railway provides this as RAILWAY_PUBLIC_DOMAIN)
# Example: https://your-app-name.up.railway.app
# IMPORTANT: Also add this as a redirect URI in Azure Portal:
#   https://your-app-name.up.railway.app/auth/callback
BASE_URL=https://your-app-name.up.railway.app

# PostgreSQL connection string (Railway auto-provides this when you add Postgres)
# DATABASE_URL=postgresql://user:pass@host:port/dbname

# AES-256 encryption key for token storage (64-character hex string = 32 bytes)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Or run: npm run generate-key
TOKEN_ENCRYPTION_KEY=your-64-char-hex-key-here

# ---------- Optional ----------

# Enable test mode with mock data (true/false)
USE_TEST_MODE=false

# Disable SSL for Postgres (only for local development)
# PG_SSL=false
